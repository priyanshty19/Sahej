# Copy to .env (kept out of git) or set these in the Vercel dashboard.

# Neon Postgres connection string. Use the POOLED host (the one with
# "-pooler" in it) so serverless functions don't exhaust connections.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Set to 1 in production (HTTPS) so the session cookie is marked Secure.
SAHEJ_SECURE=1
