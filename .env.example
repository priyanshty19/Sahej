# Copy to .env (kept out of git) or set these in the Vercel dashboard.

# Postgres connection string. Works with Supabase or Neon — use the POOLED
# host so serverless functions don't exhaust connections.
#   Supabase: Project Settings -> Database -> Connection string -> URI
#             (Connection pooling / "Transaction" mode, port 6543).
#     postgresql://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#   Neon:     the host with "-pooler" in it.
#     postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# When set, the app stores worker accounts, mother cases and consumer leads
# here, and (after seeding — see below) serves the scheme catalog from it too.
# Unset -> local SQLite (data/sahej.db) + the bundled JSON catalog.
#
# Seed the catalog + knowledge bases into the database once:
#   DATABASE_URL='postgresql://...' python3 tools/migrate_to_db.py
#   DATABASE_URL='postgresql://...' python3 tools/migrate_to_db.py --check
DATABASE_URL=

# Set to 1 in production (HTTPS) so the session cookie is marked Secure.
SAHEJ_SECURE=1

# Consumer OTP delivery. Unset -> dev mode: the code is logged and returned in
# the API response so the flow is testable. Set to your gateway's name once you
# wire it in serve.py `_deliver_otp` (e.g. "msg91" / "twilio") to disable the
# dev echo and send real SMS.
# SAHEJ_SMS_PROVIDER=
