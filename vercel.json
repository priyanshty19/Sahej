{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "includeFiles": "{web/**,data/catalog.json,data/childbirth_schemes.json,data/death_schemes.json,data/states.json,engine.py,serve.py,store.py,catalog.py}"
    }
